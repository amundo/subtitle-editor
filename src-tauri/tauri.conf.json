{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cuebert",
  "version": "0.4.1",
  "identifier": "com.pathall.cuebert",
  "build": {
    "frontendDist": "../cuebert"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Cuebert",
        "width": 1440,
        "height": 960,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/Cuebert.icns"
    ]
  }
}
